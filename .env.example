# Server Configuration
PORT=3000
NODE_ENV=development
FLASK_ENV=development

# Secrets (DO NOT COMMIT ACTUAL KEYS)
# Generate a strong secret for production
SECRET_KEY=generate_a_secure_key_for_flask
JWT_SECRET=generate_a_secure_key_for_jwt

# Database Configuration
# For production (Vercel), you might use a managed DB URL
DATABASE_URL=sqlite:///concentratrack.db

# API Configuration
API_BASE_URL=http://localhost:3000/api

# Feature Flags
ENABLE_SPEECH_SYNTHESIS=true
ENABLE_OFFLINE_MODE=true
ENABLE_ANALYTICS=true